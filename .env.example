# --------------------------------------------------
# Application
# --------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_URL=http://localhost:3000

# --------------------------------------------------
# Security
# --------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# --------------------------------------------------
# Database
# --------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/astromerchant

# --------------------------------------------------
# CORS
# --------------------------------------------------
CORS_ORIGIN=http://localhost:4321

# --------------------------------------------------
# Stellar Network
# --------------------------------------------------
STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# --------------------------------------------------
# Stellar Keys
# --------------------------------------------------
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --------------------------------------------------
# Asset Configuration
# --------------------------------------------------
ASSET_CODE=USDC
ASSET_ISSUER=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --------------------------------------------------
# Logging
# --------------------------------------------------
LOG_LEVEL=info

# --------------------------------------------------
# Rate Limiting
# --------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------------
# Optional Cache
# --------------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------------
# Email (Optional)
# --------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# --------------------------------------------------
# GitHub OAuth (Optional)
# --------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --------------------------------------------------
# Frontend
# --------------------------------------------------
FRONTEND_URL=http://localhost:4321
